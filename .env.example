# LLM Provider: openai | gigachat | ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# GigaChat
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=false

# Ollama
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medassist
DB_USER=medassist
DB_PASSWORD=medassist
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# LangSmith (optional — automatic LLM/tool tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=medassist
