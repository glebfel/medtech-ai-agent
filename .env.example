# LLM Provider: openai | anthropic | gigachat | ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# GigaChat
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=false

# Ollama
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://ollama:11434

# Health check timeout (seconds)
HEALTH_CHECK_TIMEOUT=5

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medassist
DB_USER=medassist
DB_PASSWORD=medassist
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# LangSmith (optional — automatic LLM/tool tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=medassist
