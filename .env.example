# Default LLM Provider: openai | anthropic | gigachat | ollama
DEFAULT_LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# GigaChat
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=false

# Ollama
OLLAMA_BASE_URL=http://ollama:11434

# Embeddings (semantic search)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
EMBEDDING_PULL_TIMEOUT=300

# Health check timeout (seconds)
HEALTH_CHECK_TIMEOUT=5

# User identification
USER_STORAGE_KEY=medassist_user_id

# Memory TTL (days, 0 = no expiry)
MEMORY_TTL_DAYS=90
MEMORY_SWEEP_INTERVAL_MINUTES=60

# Limits
MAX_INPUT_LENGTH=5000
MAX_VISIBLE_CHATS=15

# Context window management
MAX_CONTEXT_TOKENS=32000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medassist
DB_USER=medassist
DB_PASSWORD=medassist
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# LangSmith (optional — automatic LLM/tool tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=medassist
